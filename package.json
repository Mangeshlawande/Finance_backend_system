{
  "name": "finance_system",
  "version": "1.0.0",
  "description": "A finance Backend system ",
  "keywords": [
    "finance",
    "node",
    "express",
    "jwt",
    "zod",
    "drizzle",
    "morgan",
    "cors"
  ],
  "homepage": "https://github.com/Mangeshlawande/Finance_backend_system#readme",
  "bugs": {
    "url": "https://github.com/Mangeshlawande/Finance_backend_system/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mangeshlawande/Finance_backend_system.git"
  },
  "license": "ISC",
  "author": "mangeshlawande",
  "type": "module",
  "main": "src/index.js",
  "imports": {
    "#config/*": "./src/config/*",
    "#models/*": "./src/models/*",
    "#middleware/*": "./src/middleware/*",
    "#controllers/*": "./src/controllers/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./src/utils/*",
    "#validations/*": "./src/validations/*"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "node src/db/seed.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
